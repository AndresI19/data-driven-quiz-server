{
  "name": "data-driven-quiz-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A data-driven quiz server: drop a YAML file into cards/ and it becomes a section, with the question types inferred from the fields each card carries. Isometric garden reward system included.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx src/server/index.ts",
    "serve": "npm run build && npm start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@platform/ui": "file:vendor/portfolio-home/packages/platform-ui",
    "cross-env": "^7.0.3",
    "express": "^4.21.2",
    "gifenc": "^1.0.3",
    "js-yaml": "^4.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "happy-dom": "^15.11.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
