# Keep the build context small and the image clean. NOTE: vendor/ is deliberately NOT ignored —
# it holds the @platform/ui submodule that package.json resolves `file:vendor/platform-ui` against,
# so `npm ci` fails without it.
node_modules/
vendor/*/node_modules/
dist/
coverage/
.git/
.github/
.vite/

# Not needed at runtime
*.md
!cards/*.md
.env
.env.*
*.log
.DS_Store
.idea/
.vscode/
