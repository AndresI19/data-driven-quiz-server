# Keep the build context small and the image clean.
node_modules/
dist/
coverage/

# Tests never belong in the image; src/ is now shippable-only.
test/
**/*.test.ts
.git/
.github/
.vite/

# @platform/ui lives in the project-platform MONOREPO submodule, at
# vendor/project-platform/portfolio-home/packages/platform-ui. The monorepo also contains the whole
# home page and the auth service — none of which the quiz build needs — so this whittles the context
# down to just that one package. A negation only takes effect if every parent directory is first
# un-ignored, hence the ladder.
vendor/project-platform/*
!vendor/project-platform/portfolio-home
vendor/project-platform/portfolio-home/*
!vendor/project-platform/portfolio-home/packages
vendor/project-platform/portfolio-home/packages/*
!vendor/project-platform/portfolio-home/packages/platform-ui
vendor/project-platform/portfolio-home/packages/platform-ui/node_modules/

# Not needed at runtime
*.md
!cards/*.md
.env
.env.*
*.log
.DS_Store
.idea/
.vscode/
